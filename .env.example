# =============================
# GCP account / project
# =============================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west1
GCP_LOCATION=EU

# Credentials path used inside Docker container.
# Default recommended (ADC): /root/.config/gcloud/application_default_credentials.json
# Optional key-based mode: /workspace/secrets/gcp-sa.json
GOOGLE_APPLICATION_CREDENTIALS=/root/.config/gcloud/application_default_credentials.json

# Optional: if you prefer explicit credentials for Terraform
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# =============================
# Ingestion API credentials (ING-02 / INFRA-06)
# =============================
# Required: France Travail OAuth2
FT_CLIENT_ID=
FT_CLIENT_SECRET=

# Optional: data.gouv.fr API key (only if rate limits require auth later)
DATAGOUV_API_KEY=

# API Géo: no credentials required

# Optional runtime hints for ingestion scripts
# If empty, scripts can resolve bucket from Terraform output/config
INGESTION_RAW_BUCKET=
INGESTION_FRANCE_TRAVAIL_PREFIX=raw/france_travail/
INGESTION_SIRENE_PREFIX=raw/sirene/
INGESTION_GEO_PREFIX=raw/geo/

# =============================
# Terraform variables (auto-loaded if exported)
# =============================
TF_VAR_project_id=your-gcp-project-id
TF_VAR_region=europe-west1
TF_VAR_location=EU
TF_VAR_environment=dev
TF_VAR_project_prefix=datatalent
# Optional explicit raw bucket name override (must be globally unique and <= 63 chars)
# TF_VAR_raw_bucket_name=datatalent-dev-my-raw-bucket
TF_VAR_bucket_versioning_enabled=true
TF_VAR_bucket_force_destroy=false
TF_VAR_bucket_lifecycle_delete_age_days=365
# Transition vers NEARLINE après N jours (~40% d'économie sur Sirene). null = désactivé.
TF_VAR_bucket_nearline_age_days=30
# Suppression automatique du préfixe geo/ après N jours. null = désactivé.
TF_VAR_bucket_geo_prefix_delete_age_days=90
TF_VAR_raw_dataset_id=raw
TF_VAR_staging_dataset_id=staging
TF_VAR_marts_dataset_id=marts
TF_VAR_ingestion_france_travail_prefix=raw/france_travail/
TF_VAR_ingestion_sirene_prefix=raw/sirene/
TF_VAR_ingestion_geo_prefix=raw/geo/

# Activation progressive (false par défaut pour ne pas bloquer le premier apply)
# Passer à true après push de l'image dans Artifact Registry
TF_VAR_create_compute_job=false
# Passer à true après la première ingestion (BQ autodetect requiert des fichiers Parquet)
TF_VAR_create_external_tables=false

# Compute serverless (INFRA-04)
TF_VAR_compute_job_name=datatalent-ingestion-job
TF_VAR_compute_image=europe-west1-docker.pkg.dev/your-gcp-project-id/datatalent/ingestion:latest
TF_VAR_compute_memory=512Mi
TF_VAR_compute_cpu=1
TF_VAR_compute_timeout_seconds=1800
TF_VAR_compute_max_retries=1

# Scheduler (INFRA-05)
# Optional: if empty, scheduler falls back to TF_VAR_ingestion_service_account_email
TF_VAR_scheduler_service_account_email=
TF_VAR_scheduler_job_name_prefix=datatalent-ingestion
TF_VAR_scheduler_time_zone=Europe/Paris
TF_VAR_scheduler_france_travail_schedule=0 6 * * *
TF_VAR_scheduler_sirene_schedule=0 3 1 * *
TF_VAR_scheduler_geo_schedule=0 4 1 * *

# Secret Manager (INFRA-06)
TF_VAR_secret_ft_client_id_name=FT_CLIENT_ID
TF_VAR_secret_ft_client_secret_name=FT_CLIENT_SECRET
TF_VAR_secret_datagouv_api_key_name=DATAGOUV_API_KEY

# Service accounts (to fill once created)
TF_VAR_ingestion_service_account_email=
TF_VAR_dbt_service_account_email=
TF_VAR_dashboard_service_account_email=

# =============================
# dbt (EPIC 2)
# Used by dbt/transformation/profiles.yml and docker-compose service "dbt"
# =============================
# Target profile to use: dev (oauth via ADC) or ci (service-account keyfile)
DBT_TARGET=dev
DBT_THREADS=4

# BigQuery runtime settings
DBT_BIGQUERY_PROJECT=your-gcp-project-id
DBT_BIGQUERY_LOCATION=EU
DBT_BIGQUERY_DATASET=staging
DBT_BIGQUERY_PRIORITY=interactive
DBT_BIGQUERY_TIMEOUT_SECONDS=300
DBT_BIGQUERY_JOB_RETRIES=1

# Auth method for the selected output in profiles.yml (oauth/service-account)
DBT_BIGQUERY_METHOD=oauth
